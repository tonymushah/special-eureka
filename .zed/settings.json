{
	"lsp": {
		"rust-analyzer": {
			"initialization_options": {
				"check": {
					"command": "clippy"
				}
			}
		},
		"oxlint": {
			"initialization_options": {
				"settings": {
					"run": "onType",
					"fixKind": "safe_fix",
					"typeAware": true,
					"unusedDisableDirectives": "deny"
				}
			}
		},
		"oxfmt": {
			"initialization_options": {
				"settings": {
					"configPath": "./vite.config.ts",
					"run": "onSave"
				}
			}
		}
	},
	"file_types": {
		"JSONC": [
			"*.json5"
		]
	},
	"format_on_save": "on",
	"languages": {
		"TypeScript": {
			"code_actions_on_format": {
				"source.organizeImports": true
			},
			"format_on_save": "on",
			"language_servers": [
				"!tailwindcss-language-server",
				"eslint",
				"vtsls",
				"graphql"
			],
			"prettier": {
				"allowed": false
			},
			"formatter": [
				{
					"language_server": {
						"name": "oxfmt"
					}
				}
			]
		},
		"TSX": {
			"code_actions_on_format": {
				"source.organizeImports": true
			},
			"format_on_save": "on",
			"prettier": {
				"allowed": false
			},
			"formatter": [
				{
					"language_server": {
						"name": "oxfmt"
					}
				}
			]
		},
		"Svelte": {
			"format_on_save": "on",
			"language_servers": [
				"!tailwindcss-language-server",
				"!eslint",
				"svelte-language-server",
				"vtsls"
			]
		},
		"CSS": {
			"format_on_save": "on",
			"prettier": {
				"allowed": false
			},
			"formatter": [
				{
					"language_server": {
						"name": "oxfmt"
					}
				}
			]
		},
		"GraphQL": {
			"format_on_save": "on",
			"prettier": {
				"allowed": false
			},
			"formatter": [
