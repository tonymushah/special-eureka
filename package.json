{
	"name": "special-eureka",
	"version": "0.2.4",
	"scripts": {
		"vite:dev": "vp dev",
		"codegen": "graphql-codegen",
		"codegen:mangadex": "pnpm codegen -c ./src/lib/mangadex/codegen.ts && vp fmt --write src/lib/mangadex/gql",
		"vite:build_preview": "pnpm vite:build && pnpm vite:preview",
		"vite:build": "vp build --emptyOutDir",
		"vite:preview": "vp preview --port 9305",
		"dev": "tauri dev",
		"dev:next": "RUSTFLAGS='--cfg reqwest_unstable' tauri dev --features next",
		"dev:hotpath": "tauri dev -f hotpath",
		"dev:hotpath:alloc": "tauri dev -f hotpath-alloc",
		"dev:jemalloc": "tauri dev -f jemalloc",
		"build": "tauri build",
		"preview": "pnpm vite:preview",
		"test": "npm run test:integration && npm run test:unit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "vp fmt --check ./src && vp lint ./src --tsconfig ./tsconfig.json",
		"format": "vp fmt ./src",
		"test:integration": "playwright test",
		"test:unit": "vp test",
		"cargo:clean": "cargo clean",
		"cargo:clippy": "cargo clippy",
		"cargo:build": "cargo build",
		"build:no-bundle": "pnpm vite:build && cargo build -r --no-default-features -F no_bundle",
		"build:no-bundle:next": "pnpm vite:build && RUSTFLAGS='--cfg reqwest_unstable' cargo build -r --no-default-features -F no_bundle,next",
		"clippy": "cargo clippy",
		"clippy:next": "RUSTFLAGS='--cfg reqwest_unstable' cargo clippy -F next"
	},
	"devDependencies": {
		"@graphql-codegen/cli": "^7.0.0",
		"@graphql-codegen/client-preset": "^6.0.0",
		"@parcel/watcher": "^2.5.6",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tanstack/svelte-query-devtools": "^6.1.28",
		"@tauri-apps/cli": "^2.11.1",
		"@types/node": "^24",
		"globals": "^17.4.0",
		"graphql": "^16.14.0",
		"graphql-config": "^5.1.6",
		"less": "^4.6.4",
		"sass": "^1.99.0",
		"sharp": "^0.34.5",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"svgo": "^4.0.1",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"vite": "catalog:",
		"vite-plugin-image-optimizer": "^2.0.3",
		"vite-plugin-kit-routes": "^1.0.4",
		"vite-plus": "catalog:",
		"vitest": "catalog:"
	},
	"type": "module",
	"dependencies": {
		"@ark-ui/svelte": "^5.21.2",
		"@floating-ui/dom": "^1.7.6",
		"@fontsource-variable/josefin-sans": "^5.2.8",
		"@fontsource-variable/lexend": "^5.2.11",
		"@fontsource/pacifico": "^5.2.7",
		"@fontsource/poppins": "^5.2.7",
		"@graphql-typed-document-node/core": "^3.2.0",
		"@humanspeak/svelte-markdown": "^1.4.5",
		"@icons-pack/svelte-simple-icons": "^7.2.0",
		"@lucide/svelte": "^1.14.0",
		"@panzoom/panzoom": "^4.6.2",
		"@tanstack/svelte-query": "^6.1.28",
		"@tanstack/table-core": "^8.21.3",
		"@tauri-apps/api": "^2.11.0",
		"@tauri-apps/plugin-clipboard-manager": "^2.3.2",
		"@tauri-apps/plugin-dialog": "^2.7.1",
		"@tauri-apps/plugin-opener": "^2.5.4",
		"@urql/svelte": "^5.0.0",
		"@viselect/vanilla": "^3.9.0",
		"core-js": "^3.49.0",
		"es-toolkit": "^1.46.1",
		"fast-xml-parser": "^5.7.3",
		"flag-icons": "^7.5.0",
		"hotkeys-js": "^4.0.4",
		"medium-zoom": "^1.1.0",
		"mizuki-urql-adapter": "^1.1.0",
		"panzoom": "^9.4.4",
		"runed": "^0.37.1",
		"svelte-awesome-color-picker": "^4.1.2",
		"swiper": "^12.1.4",
		"timeago.js": "^4.0.2",
		"uuid": "^14.0.0"
	},
	"packageManager": "pnpm@11.1.1",
	"engines": {
		"node": ">=24"
	}
}