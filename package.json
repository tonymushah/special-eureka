{
	"name": "special-eureka",
	"version": "0.2.3",
	"scripts": {
		"vite:dev": "vite dev",
		"codegen": "graphql-codegen",
		"codegen:mangadex": "pnpm codegen -c ./src/lib/mangadex/codegen.ts && pnpm prettier -w src/lib/mangadex/gql",
		"vite:build_preview": "pnpm vite:build && pnpm vite:preview",
		"vite:build": "vite build --emptyOutDir",
		"vite:preview": "vite preview --port 9305",
		"dev": "tauri dev",
		"dev:next": "RUSTFLAGS='--cfg reqwest_unstable' tauri dev -F next",
		"dev:hotpath": "tauri dev -f hotpath",
		"dev:hotpath:alloc": "tauri dev -f hotpath-alloc",
		"dev:jemalloc": "tauri dev -f jemalloc",
		"build": "tauri build",
		"preview": "pnpm vite:preview",
		"test": "npm run test:integration && npm run test:unit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check ./src && eslint ./src",
		"format": "prettier --write ./src",
		"test:integration": "playwright test",
		"test:unit": "vitest",
		"cargo:clean": "cargo clean",
		"cargo:clippy": "cargo clippy",
		"cargo:build": "cargo build",
		"build:no-bundle": "pnpm vite:build && cargo build -r --no-default-features -F custom-protocol",
		"build:no-bundle:next": "RUSTFLAGS='--cfg reqwest_unstable' pnpm vite:build && cargo build -r --no-default-features -F custom-protocol,next",
		"clippy": "cargo clippy",
		"clippy:next": "RUSTFLAGS='--cfg reqwest_unstable' cargo clippy -F next"
	},
	"devDependencies": {
		"@eslint/css": "^1.0.0",
		"@eslint/js": "^10.0.1",
		"@graphql-codegen/cli": "^6.2.1",
		"@graphql-codegen/client-preset": "^5.2.4",
		"@parcel/watcher": "^2.5.6",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tanstack/svelte-query-devtools": "^6.1.10",
		"@tauri-apps/cli": "^2.10.1",
		"@types/lodash": "^4.17.24",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"@viselect/vanilla": "^3.9.0",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"graphql": "^16.13.2",
		"graphql-config": "^5.1.6",
		"less": "^4.6.4",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"sass": "^1.98.0",
		"sharp": "^0.34.5",
		"svelte": "^5.55.0",
		"svelte-awesome-color-picker": "^4.1.1",
		"svelte-check": "^4.4.5",
		"svelte2tsx": "~0.7.52",
		"svgo": "^4.0.1",
		"tslib": "^2.8.1",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.57.2",
		"vite": "^8.0.2",
		"vite-plugin-image-optimizer": "^2.0.3",
		"vite-plugin-kit-routes": "^1.0.2",
		"vitest": "^4.1.1"
	},
	"type": "module",
	"dependencies": {
		"@ark-ui/svelte": "^5.19.1",
		"@floating-ui/dom": "^1.7.6",
		"@fontsource-variable/josefin-sans": "^5.2.8",
		"@fontsource-variable/lexend": "^5.2.11",
		"@fontsource/pacifico": "^5.2.7",
		"@fontsource/poppins": "^5.2.7",
		"@graphiql/toolkit": "~0.11.3",
		"@graphql-typed-document-node/core": "^3.2.0",
		"@humanspeak/svelte-markdown": "^1.0.5",
		"@icons-pack/svelte-simple-icons": "^7.2.0",
		"@lucide/svelte": "^1.6.0",
		"@panzoom/panzoom": "^4.6.1",
		"@tanstack/svelte-query": "^6.1.10",
		"@tanstack/table-core": "^8.21.3",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-clipboard-manager": "^2.3.2",
		"@tauri-apps/plugin-dialog": "^2.6.0",
		"@tauri-apps/plugin-notification": "^2.3.3",
		"@tauri-apps/plugin-opener": "^2.5.3",
		"@urql/svelte": "^5.0.0",
		"core-js": "^3.49.0",
		"fast-xml-parser": "^5.5.9",
		"flag-icons": "^7.5.0",
		"graphiql": "^5.2.2",
		"hotkeys-js": "^4.0.2",
		"lodash": "^4.17.23",
		"medium-zoom": "^1.1.0",
		"mizuki-graphiql-fetcher": "^1.1.0",
		"mizuki-urql-adapter": "^1.1.0",
		"panzoom": "^9.4.3",
		"runed": "^0.37.1",
		"swiper": "^12.1.3",
		"timeago.js": "^4.0.2",
		"uuid": "^13.0.0"
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=24"
	}
}
